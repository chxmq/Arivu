{
  "expo": {
    "name": "Arivu",
    "slug": "arivu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arivu",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Arivu needs microphone access to record elder knowledge during field sessions.",
        "NSLocationWhenInUseUsageDescription": "Arivu captures grove GPS location to geotag knowledge entries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A4731",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F0EBE0"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Arivu needs microphone access to record elder knowledge during field sessions."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Arivu captures grove GPS location to geotag knowledge entries."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

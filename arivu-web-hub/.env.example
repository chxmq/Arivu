# ─────────────────────────────────────────────────────────────
# SITE / HUB — copy this file to:  site/.env
# Then run:  cd site && node server/hub.mjs
# ─────────────────────────────────────────────────────────────

# Optional — GPT-style Command Board assistant (◈ button on website)
# Without this, assistant still works with rule-based answers.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional — hub listen address (default 0.0.0.0:8787)
# ARIVU_HUB_HOST=0.0.0.0
# ARIVU_HUB_PORT=8787
